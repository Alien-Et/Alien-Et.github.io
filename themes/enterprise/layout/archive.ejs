<section class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-hero-content">
      <h1 class="page-title animate-fade-up"><%= page.title || __('news.title') %></h1>
      <p class="page-subtitle animate-fade-up delay-1"><%= __('news.subtitle') %></p>
      <nav class="breadcrumb animate-fade-up delay-2">
        <a href="<%= url_for('/') %>"><%= __('menu.home') %></a>
        <i class="fas fa-chevron-right"></i>
        <span><%= page.title || __('news.title') %></span>
      </nav>
    </div>
  </div>
</section>

<section class="news-section">
  <div class="container">
    <div class="news-filter">
      <button class="filter-btn active" data-filter="all"><%= __('news.categories.all') %></button>
      <button class="filter-btn" data-filter="company"><%= __('news.categories.company') %></button>
      <button class="filter-btn" data-filter="industry"><%= __('news.categories.industry') %></button>
      <button class="filter-btn" data-filter="tech"><%= __('news.categories.tech') %></button>
    </div>
    
    <div class="news-grid">
      <% if (page.posts && page.posts.length > 0) { %>
        <% page.posts.each(function(post) { %>
        <article class="news-card animate-on-scroll" data-category="<%= post.category || 'company' %>">
          <div class="news-image">
            <% if (post.cover) { %>
            <img src="<%= post.cover %>" alt="<%= post.title %>">
            <% } else { %>
            <div class="news-image-placeholder">
              <i class="fas fa-newspaper"></i>
            </div>
            <% } %>
            <div class="news-date">
              <span class="day"><%= date(post.date, 'DD') %></span>
              <span class="month"><%= date(post.date, 'YYYY-MM') %></span>
            </div>
          </div>
          <div class="news-content">
            <div class="news-meta">
              <span class="news-category"><%= post.category || __('news.categories.company') %></span>
              <span class="news-views"><i class="fas fa-eye"></i> <%= post.views || Math.floor(Math.random() * 500 + 100) %></span>
            </div>
            <h3 class="news-title">
              <a href="<%= url_for(post.path) %>"><%= post.title %></a>
            </h3>
            <p class="news-excerpt"><%= strip_html(post.excerpt || post.content).substring(0, 120) %>...</p>
            <a href="<%= url_for(post.path) %>" class="news-link">
              <%= __('news.read_more') %> <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </article>
        <% }); %>
      <% } else { %>
        <div class="no-posts">
          <p><%= __('common.loading') %></p>
        </div>
      <% } %>
    </div>
    
    <% if (page.total > 1) { %>
    <div class="pagination">
      <%- paginator({
        prev_text: __('pagination.prev'),
        next_text: __('pagination.next'),
        mid_size: 2
      }) %>
    </div>
    <% } %>
  </div>
</section>