<section class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-hero-content">
      <h1 class="page-title animate-fade-up"><%= __('about.title') %></h1>
      <p class="page-subtitle animate-fade-up delay-1"><%= __('about.subtitle') %></p>
      <nav class="breadcrumb animate-fade-up delay-2">
        <a href="<%= url_for('/') %>"><%= __('menu.home') %></a>
        <i class="fas fa-chevron-right"></i>
        <span><%= __('about.title') %></span>
      </nav>
    </div>
  </div>
</section>

<section class="about-intro">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-content animate-on-scroll">
        <span class="section-tag"><%= __('about.intro.tag') %></span>
        <h2 class="section-title text-left"><%= __('about.intro.title') %></h2>
        <p><%= __('about.intro.content') %></p>
        <p><%= __('about.intro.address') %></p>
        <div class="intro-features">
          <div class="intro-feature">
            <i class="fas fa-check-circle"></i>
            <span><%= __('about.intro.cert1') %></span>
          </div>
          <div class="intro-feature">
            <i class="fas fa-check-circle"></i>
            <span><%= __('about.intro.cert2') %></span>
          </div>
          <div class="intro-feature">
            <i class="fas fa-check-circle"></i>
            <span><%= __('about.intro.cert3') %></span>
          </div>
        </div>
      </div>
      <div class="intro-image animate-on-scroll" data-delay="200">
        <div class="image-wrapper">
          <img src="/images/about/company.svg" alt="Company">
          <div class="image-badge">
            <span class="badge-number">15+</span>
            <span class="badge-text"><%= __('statistics.items.experience') %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="timeline-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag"><%= __('about.history.title') %></span>
      <h2 class="section-title"><%= __('about.history.subtitle') %></h2>
      <div class="section-line"></div>
    </div>
    <div class="timeline">
      <div class="timeline-item animate-on-scroll">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2010</span>
          <h3><%= __('about.history.2010.title') %></h3>
          <p><%= __('about.history.2010.content') %></p>
        </div>
      </div>
      <div class="timeline-item animate-on-scroll" data-delay="100">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2013</span>
          <h3><%= __('about.history.2013.title') %></h3>
          <p><%= __('about.history.2013.content') %></p>
        </div>
      </div>
      <div class="timeline-item animate-on-scroll" data-delay="200">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2016</span>
          <h3><%= __('about.history.2016.title') %></h3>
          <p><%= __('about.history.2016.content') %></p>
        </div>
      </div>
      <div class="timeline-item animate-on-scroll" data-delay="300">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2019</span>
          <h3><%= __('about.history.2019.title') %></h3>
          <p><%= __('about.history.2019.content') %></p>
        </div>
      </div>
      <div class="timeline-item animate-on-scroll" data-delay="400">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2022</span>
          <h3><%= __('about.history.2022.title') %></h3>
          <p><%= __('about.history.2022.content') %></p>
        </div>
      </div>
      <div class="timeline-item animate-on-scroll" data-delay="500">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-year">2025</span>
          <h3><%= __('about.history.2025.title') %></h3>
          <p><%= __('about.history.2025.content') %></p>
        </div>
      </div>
    </div>
  </div>
</section>

