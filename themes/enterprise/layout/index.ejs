<section class="hero-section">
  <div class="hero-particles" id="particles"></div>
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-title animate-fade-up">
        <span class="gradient-text"><%= __('index.hero.title') %></span>
      </h1>
      <p class="hero-subtitle animate-fade-up delay-1"><%= __('index.hero.subtitle') %></p>
      <div class="hero-cta animate-fade-up delay-2">
        <a href="<%= url_for('/about/') %>" class="btn btn-primary btn-glow">
          <span><%= __('index.hero.cta') %></span>
          <i class="fas fa-arrow-right"></i>
        </a>
        <a href="<%= url_for('/contact/') %>" class="btn btn-outline">
          <%= __('index.hero.contact') %>
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-shape shape-1"></div>
      <div class="hero-shape shape-2"></div>
      <div class="hero-shape shape-3"></div>
      <div class="floating-card card-1">
        <i class="fas fa-solar-panel"></i>
        <span><%= __('floating_cards.capacity') %></span>
      </div>
      <div class="floating-card card-2">
        <i class="fas fa-globe-asia"></i>
        <span><%= __('floating_cards.countries') %></span>
      </div>
      <div class="floating-card card-3">
        <i class="fas fa-leaf"></i>
        <span><%= __('floating_cards.energy') %></span>
      </div>
    </div>
  </div>
  <div class="scroll-indicator">
    <div class="mouse">
      <div class="wheel"></div>
    </div>
    <span><%= __('index.hero.scroll') %></span>
  </div>
</section>

<% if (theme.features.enable) { %>
<section class="features-section" id="features">
  <div class="container">
    <div class="section-header">
      <span class="section-tag"><%= __('features.tag') %></span>
      <h2 class="section-title"><%= __('features.title') %></h2>
      <div class="section-line"></div>
    </div>
    <div class="features-grid">
      <div class="feature-card animate-on-scroll" data-delay="0">
        <div class="feature-icon">
          <i class="fas fa-solar-panel"></i>
        </div>
        <h3 class="feature-title"><%= __('features.items.tech.title') %></h3>
        <p class="feature-desc"><%= __('features.items.tech.desc') %></p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="100">
        <div class="feature-icon">
          <i class="fas fa-leaf"></i>
        </div>
        <h3 class="feature-title"><%= __('features.items.green.title') %></h3>
        <p class="feature-desc"><%= __('features.items.green.desc') %></p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="200">
        <div class="feature-icon">
          <i class="fas fa-battery-full"></i>
        </div>
        <h3 class="feature-title"><%= __('features.items.storage.title') %></h3>
        <p class="feature-desc"><%= __('features.items.storage.desc') %></p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="300">
        <div class="feature-icon">
          <i class="fas fa-globe-asia"></i>
        </div>
        <h3 class="feature-title"><%= __('features.items.global.title') %></h3>
        <p class="feature-desc"><%= __('features.items.global.desc') %></p>
      </div>
    </div>
  </div>
</section>
<% } %>

<% if (theme.products.enable) { %>
<section class="products-section" id="products">
  <div class="container">
    <div class="section-header">
      <span class="section-tag"><%= __('products.title') %></span>
      <h2 class="section-title"><%= __('products.subtitle') %></h2>
      <div class="section-line"></div>
    </div>
    <div class="products-grid">
      <div class="product-card animate-on-scroll" data-delay="0">
        <div class="product-icon">
          <i class="fas fa-solar-panel"></i>
        </div>
        <h3 class="product-title"><%= __('products.categories.solar') %></h3>
        <p class="product-desc"><%= __('products.desc.solar') %></p>
        <a href="<%= url_for('/products/') %>#solar" class="product-link">
          <%= __('products.learn_more') %> <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <div class="product-card animate-on-scroll" data-delay="100">
        <div class="product-icon">
          <i class="fas fa-battery-full"></i>
        </div>
        <h3 class="product-title"><%= __('products.categories.battery') %></h3>
        <p class="product-desc"><%= __('products.desc.battery') %></p>
        <a href="<%= url_for('/products/') %>#battery" class="product-link">
          <%= __('products.learn_more') %> <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <div class="product-card animate-on-scroll" data-delay="200">
        <div class="product-icon">
          <i class="fas fa-industry"></i>
        </div>
        <h3 class="product-title"><%= __('products.categories.station') %></h3>
        <p class="product-desc"><%= __('products.desc.station') %></p>
        <a href="<%= url_for('/products/') %>#station" class="product-link">
          <%= __('products.learn_more') %> <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <div class="product-card animate-on-scroll" data-delay="300">
        <div class="product-icon">
          <i class="fas fa-microchip"></i>
        </div>
        <h3 class="product-title"><%= __('products.categories.smart') %></h3>
        <p class="product-desc"><%= __('products.desc.smart') %></p>
        <a href="<%= url_for('/products/') %>#smart" class="product-link">
          <%= __('products.learn_more') %> <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </div>
</section>
<% } %>

<% if (theme.statistics.enable) { %>
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item animate-on-scroll" data-delay="0">
        <div class="stat-number">
          <span class="count" data-target="15">15</span>
          <span class="suffix">+</span>
        </div>
        <div class="stat-label"><%= __('statistics.items.experience') %></div>
      </div>
      <div class="stat-item animate-on-scroll" data-delay="100">
        <div class="stat-number">
          <span class="count" data-target="300">300</span>
          <span class="suffix">+</span>
        </div>
        <div class="stat-label"><%= __('statistics.items.patents') %></div>
      </div>
      <div class="stat-item animate-on-scroll" data-delay="200">
        <div class="stat-number">
          <span class="count" data-target="50">50</span>
          <span class="suffix">+</span>
        </div>
        <div class="stat-label"><%= __('statistics.items.countries') %></div>
      </div>
      <div class="stat-item animate-on-scroll" data-delay="300">
        <div class="stat-number">
          <span class="count" data-target="10">10</span>
          <span class="suffix">GW+</span>
        </div>
        <div class="stat-label"><%= __('statistics.items.capacity') %></div>
      </div>
    </div>
  </div>
</section>
<% } %>

