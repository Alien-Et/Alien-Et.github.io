<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title"><%= __('site.slogan') %></h2>
      <p class="cta-desc"><%= __('site.description') %></p>
      <a href="<%= url_for('/contact/') %>" class="btn btn-primary btn-glow">
        <%= __('index.hero.contact') %> <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>